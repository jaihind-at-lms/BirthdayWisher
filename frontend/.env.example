# Copy this file to .env and fill in the values
# Never commit .env to version control

# Dev server port
VITE_PORT=7000

# Base path for the router (use "/" for root)
VITE_ROUTER_BASE_PATH="/"

# Backend API base URL
VITE_API_BASE_URL=https://your-api-url.com

# App secret key (used for client-side encoding only — NOT real encryption)
VITE_APP_SECRET_KEY=your-secret-key-here

# Sheet tab names (must match backend route path segments)
VITE_SHEET_WISHES_TAB=wishes
VITE_SHEET_DEPARTMENTS_TAB=departments
VITE_SHEET_DESIGNATIONS_TAB=designations
